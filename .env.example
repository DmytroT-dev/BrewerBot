v# GitHub
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_USERNAME=your_github_username
# Optional: comma-separated repo names, e.g. my-repo,another-repo. Leave empty for all repos.
GITHUB_REPOS=

# Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHANNEL_ID=@your_channel_username
# Or use numeric ID: TELEGRAM_CHANNEL_ID=-1001234567890

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: override cron schedules
# GITHUB_CHECK_CRON=0 */30 * * * *
# JAVA_NEWS_CRON=0 0 */3 * * *
# AI_NEWS_CRON=0 30 */4 * * *

# Optional: path to state file (default: ./bot-state.json)
# STATE_FILE_PATH=./bot-state.json
